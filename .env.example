# Copy to .env and fill in. .env is gitignored.
#
# Pick a provider by setting its API key. You can set one or both.
# OpenRouter (default): reaches a wide catalog of models.
OPENROUTER_API_KEY=sk-or-...
# OpenAI: native API (uses the openai SDK's default base URL).
OPENAI_API_KEY=sk-...
#
# Which provider to use. Optional — if unset it's inferred from whichever key is present;
# when BOTH keys are set, openrouter wins unless you set this. Values: openrouter | openai
PROVIDER=openrouter
#
# Optional: starting model id (provider-specific). Defaults per provider:
#   openrouter → deepseek/deepseek-v4-flash
#   openai     → gpt-5.5
# AGENT_MODEL=gpt-5.5
