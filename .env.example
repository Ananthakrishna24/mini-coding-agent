# Copy to .env and fill in. .env is gitignored.
#
# Pick a provider by setting its API key. You can set one or more.
# OpenRouter (default): reaches a wide catalog of models.
OPENROUTER_API_KEY=sk-or-...
# OpenAI: native API (uses the openai SDK's default base URL).
OPENAI_API_KEY=sk-...
# OpenAI via Codex login: run `codex login`, then set:
# PROVIDER=openai
# OPENAI_AUTH=codex
# You can also provide a non-persisted ChatGPT/Codex token:
# CODEX_ACCESS_TOKEN=...
# Mistral: native Mistral API.
MISTRAL_API_KEY=...
#
# Which provider to use. Optional — if unset it's inferred from whichever key is present;
# when multiple keys are set, openrouter wins unless you set this. Values: openrouter | openai | mistral
PROVIDER=openrouter
# Optional OpenAI auth mode. Values: api-key | codex
# OPENAI_AUTH=api-key
#
# Optional: starting model id (provider-specific). Defaults per provider:
#   openrouter → deepseek/deepseek-v4-flash
#   openai     → gpt-5.5
#   mistral    → mistral-large-latest
# AGENT_MODEL=gpt-5.5
#
# Optional: free Jina API key for the web_search tool (s.jina.ai now requires it).
# Get one at https://jina.ai/api-dashboard/ . web_fetch stays keyless without it.
# JINA_API_KEY=jina_...
